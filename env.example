# CloudSweeper Environment Variables
# =====================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it's in .gitignore.
#
# Usage: cp .env.example .env

# ------------------------------------------------------------------ #
# AWS Identity                                                         #
# ------------------------------------------------------------------ #

# Your 12-digit AWS account ID (visible in AWS Console > top-right menu)
AWS_ACCOUNT_ID=

# AWS region where your CloudTrail and target resources live
AWS_REGION=eu-west-2

# Named profile from ~/.aws/credentials (use "default" if you only have one)
AWS_PROFILE=default

# ------------------------------------------------------------------ #
# CloudTrail / Logging                                                 #
# ------------------------------------------------------------------ #

# S3 bucket where CloudTrail writes logs — created in Lab Step 4
CLOUDTRAIL_BUCKET=my-cloudtrail-logs-406214277032

# Prefix CloudTrail uses inside the bucket (default: AWSLogs)
CLOUDTRAIL_PREFIX=AWSLogs

# How many hours back the detection engine looks when scanning logs
DETECTION_LOOKBACK_HOURS=24

# ------------------------------------------------------------------ #
# Detection Thresholds                                                 #
# ------------------------------------------------------------------ #

# IAM read API calls in the lookback window = recon spike
RECON_SPIKE_THRESHOLD=20

# S3 list calls in the lookback window = enumeration flag
S3_ENUM_THRESHOLD=10

# AssumeRole calls in the lookback window = priv-esc indicator
PRIVESC_ASSUMEROLE_THRESHOLD=5

# ------------------------------------------------------------------ #
# Attack Simulation                                                    #
# ------------------------------------------------------------------ #

# IAM user to target during simulation — DemoDev created in Lab Step 2
SIM_TARGET_USER=DemoDev

# IMPORTANT: Keep this true unless you are intentionally remediating live resources
DRY_RUN=true

# ------------------------------------------------------------------ #
# Output                                                               #
# ------------------------------------------------------------------ #

# Directory where incident reports are written (relative to repo root)
REPORT_OUTPUT_DIR=reports

# DEBUG for human-readable logs, INFO for JSON structured logs
LOG_LEVEL=INFO
